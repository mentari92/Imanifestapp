{
  "buildCommand": "cd apps/mobile-web && npx expo export --platform web",
  "outputDirectory": "apps/mobile-web/dist",
  "installCommand": "npm install -g pnpm && pnpm install --no-frozen-lockfile",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Embedder-Policy", "value": "unsafe-none" },
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
      ]
    }
  ],
  "env": {
    "EXPO_PUBLIC_API_URL": "https://api.imanifestapp.com"
  }
}
