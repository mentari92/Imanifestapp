# ─── Stage 1: Build Expo web (static export) ─────────────────
FROM node:20-alpine AS builder
RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Copy workspace config for layer caching
COPY pnpm-workspace.yaml pnpm-lock.yaml package.json ./
COPY apps/mobile-web/package.json apps/mobile-web/
COPY packages/shared/package.json packages/shared/

RUN pnpm install --no-frozen-lockfile

# Copy source
COPY apps/mobile-web/ apps/mobile-web/
COPY packages/shared/ packages/shared/
COPY tsconfig.json ./

# Build shared package first (mobile-web depends on it)
RUN cd packages/shared && npx tsc

# Bake in the production API URL at build time
ARG EXPO_PUBLIC_API_URL=https://api.imanifestapp.com
ENV EXPO_PUBLIC_API_URL=$EXPO_PUBLIC_API_URL
ARG EXPO_PUBLIC_DEMO_AUTH_MODE=false
ENV EXPO_PUBLIC_DEMO_AUTH_MODE=$EXPO_PUBLIC_DEMO_AUTH_MODE
ARG EXPO_PUBLIC_OAUTH_ONLY=false
ENV EXPO_PUBLIC_OAUTH_ONLY=$EXPO_PUBLIC_OAUTH_ONLY

RUN cd apps/mobile-web && npx expo export --platform web

# ─── Stage 2: Serve static files via nginx ────────────────────
FROM nginx:alpine AS runner
COPY --from=builder /app/apps/mobile-web/dist /usr/share/nginx/html
COPY nginx-web.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
